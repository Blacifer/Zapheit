#!/usr/bin/env bash
# deploy/gcp/secrets.sh.example
# Template for populating all Secret Manager secrets for Zapheit production.
#
# Usage:
#   cp deploy/gcp/secrets.sh.example deploy/gcp/secrets.sh
#   # Fill in real values in secrets.sh (it is gitignored — never commit with real values)
#   export PROJECT_ID=rasisynthetichr
#   bash deploy/gcp/secrets.sh

set -euo pipefail

PROJECT_ID="${PROJECT_ID:?Set PROJECT_ID env var first}"

secret() {
  local NAME="$1"
  local VALUE="$2"
  if [ -z "${VALUE}" ] || [[ "${VALUE}" == COPY_FROM_* ]] || [[ "${VALUE}" == FILL_* ]]; then
    echo "  [SKIP] ${NAME} — placeholder not filled, skipping"
    return
  fi
  gcloud secrets describe "${NAME}" --project="${PROJECT_ID}" &>/dev/null \
    || gcloud secrets create "${NAME}" \
         --replication-policy=automatic \
         --project="${PROJECT_ID}"
  echo -n "${VALUE}" | gcloud secrets versions add "${NAME}" \
    --data-file=- --project="${PROJECT_ID}"
  echo "  [OK]   ${NAME}"
}

echo ""
echo "=== Zapheit Secret Manager Setup ==="
echo "  Project: ${PROJECT_ID}"
echo ""

# ── Core ──────────────────────────────────────────────────────────────────────
secret NODE_ENV                     "production"
secret PORT                         "3001"

# ── Supabase (Dashboard → Project Settings → API) ─────────────────────────────
secret SUPABASE_URL                 "https://XXXX.supabase.co"
secret SUPABASE_ANON_KEY            "COPY_FROM_SUPABASE_DASHBOARD"
secret SUPABASE_SERVICE_KEY         "COPY_FROM_SUPABASE_DASHBOARD"
secret JWT_SECRET                   "COPY_FROM_SUPABASE_DASHBOARD"
# Dashboard → Project Settings → Database → Connection string (URI mode)
secret DATABASE_URL                 "postgresql://postgres.XXXX:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# ── URLs ──────────────────────────────────────────────────────────────────────
secret FRONTEND_URL                 "https://www.zapheit.com"
secret API_URL                      "FILL_AFTER_FIRST_DEPLOY"   # Cloud Run URL
secret CORS_ALLOWED_ORIGINS         "https://www.zapheit.com"

# ── Encryption (CRITICAL: copy exact values — changing these breaks encrypted data) ──
secret INTEGRATIONS_ENCRYPTION_KEY  "COPY_FROM_RAILWAY"   # openssl rand -hex 32
secret ERASURE_SIGNING_SALT         "COPY_FROM_RAILWAY"   # openssl rand -hex 16

# ── AI Providers ──────────────────────────────────────────────────────────────
secret OPENAI_API_KEY               "sk-proj-..."
secret ANTHROPIC_API_KEY            "sk-ant-api03-..."
secret RASI_OPENAI_API_KEY          "sk-proj-..."    # gateway quota key
secret RASI_ANTHROPIC_API_KEY       "sk-ant-api03-..." # gateway quota key
secret RASI_OPENROUTER_API_KEY      "sk-or-v1-..."

# ── Email (Resend dashboard → API Keys) ───────────────────────────────────────
secret EMAIL_PROVIDER               "resend"
secret EMAIL_FROM                   "hello@zapheit.com"
secret ALERT_EMAIL_TO               "hello@zapheit.com"
secret RESEND_API_KEY               "re_..."

# ── Payments (Cashfree dashboard) ─────────────────────────────────────────────
secret CASHFREE_CLIENT_ID           "COPY_FROM_CASHFREE_DASHBOARD"
secret CASHFREE_CLIENT_SECRET       "cfsk_ma_prod_..."
secret CASHFREE_API_VERSION         "2023-08-01"
secret CASHFREE_ENVIRONMENT         "production"
secret CASHFREE_WEBHOOK_SECRET      "cfsk_ma_prod_..."

# ── OAuth Integrations ────────────────────────────────────────────────────────
secret GOOGLE_CLIENT_ID             "COPY_FROM_GOOGLE_CONSOLE.apps.googleusercontent.com"
secret GOOGLE_CLIENT_SECRET         "GOCSPX-..."
secret SLACK_CLIENT_ID              "COPY_FROM_SLACK_APP"
secret SLACK_CLIENT_SECRET          "COPY_FROM_SLACK_APP"
secret SLACK_SIGNING_SECRET         "COPY_FROM_SLACK_APP"
secret MICROSOFT_CLIENT_ID          "COPY_FROM_AZURE_APP_REG"
secret MICROSOFT_CLIENT_SECRET      "COPY_FROM_AZURE_APP_REG"
secret ZOHO_CLIENT_ID               "COPY_FROM_ZOHO_API_CONSOLE"
secret ZOHO_CLIENT_SECRET           "COPY_FROM_ZOHO_API_CONSOLE"
secret LINKEDIN_CLIENT_ID           "COPY_FROM_LINKEDIN_APP"
secret LINKEDIN_CLIENT_SECRET       "COPY_FROM_LINKEDIN_APP"
secret SALESFORCE_CLIENT_ID         "COPY_FROM_SALESFORCE_CONNECTED_APP"
secret SALESFORCE_CLIENT_SECRET     "COPY_FROM_SALESFORCE_CONNECTED_APP"
secret INTERCOM_CLIENT_ID           "COPY_FROM_INTERCOM_APP"
secret INTERCOM_CLIENT_SECRET       "COPY_FROM_INTERCOM_APP"
secret QUICKBOOKS_CLIENT_ID         "COPY_FROM_INTUIT_DEVELOPER"
secret QUICKBOOKS_CLIENT_SECRET     "COPY_FROM_INTUIT_DEVELOPER"
secret DEEL_CLIENT_ID               "COPY_FROM_DEEL_DEVELOPER"
secret DEEL_CLIENT_SECRET           "COPY_FROM_DEEL_DEVELOPER"
secret GUSTO_CLIENT_ID              "COPY_FROM_GUSTO_DEVELOPER"
secret GUSTO_CLIENT_SECRET          "COPY_FROM_GUSTO_DEVELOPER"
secret FLOCK_CLIENT_ID              "COPY_FROM_FLOCK_DEVELOPER"
secret FLOCK_CLIENT_SECRET          "COPY_FROM_FLOCK_DEVELOPER"
secret HUBSPOT_CLIENT_ID            "COPY_FROM_HUBSPOT_APP"
secret HUBSPOT_CLIENT_SECRET        "COPY_FROM_HUBSPOT_APP"

# ── Feature Flags ─────────────────────────────────────────────────────────────
secret CONNECTORS_ENABLED           "true"
secret CROSS_BORDER_PII_MASKING     "false"
secret SCHEMA_COMPAT_STRICT_OPTIONAL "true"
secret REDTEAM_INTERVAL_MINUTES     "0"
secret RECRUITMENT_SCORING_MODEL    "gpt-4o-mini"

# ── Observability ─────────────────────────────────────────────────────────────
secret OTEL_ENABLED                 "false"
secret OTEL_EXPORTER_OTLP_ENDPOINT  "http://localhost:4317"
secret OTEL_EXPORTER_OTLP_TIMEOUT   "10000"   # milliseconds — NOT "true"
secret OTEL_EXPORTER_OTLP_INSECURE  "true"
secret OTEL_TRACES_EXPORTER         "console"
secret OTEL_METRICS_EXPORTER        "console"

# ── Runtime worker (fill AFTER first API deploy) ──────────────────────────────
# ZAPHEIT_CONTROL_PLANE_URL = Cloud Run API URL from gcloud run services describe
# ZAPHEIT_RUNTIME_ID        = runtime instance ID from Fleet page
# ZAPHEIT_ENROLLMENT_TOKEN  = one-time token from Fleet page (create runtime instance)
secret ZAPHEIT_CONTROL_PLANE_URL "FILL_AFTER_FIRST_DEPLOY"
secret ZAPHEIT_API_KEY           "FILL_AFTER_FIRST_DEPLOY"
secret ZAPHEIT_RUNTIME_ID        "FILL_AFTER_FIRST_DEPLOY"
secret ZAPHEIT_ENROLLMENT_TOKEN  "FILL_AFTER_FIRST_DEPLOY"
secret ZAPHEIT_MODEL             "gpt-4o"

echo ""
echo "=== Secrets setup complete ==="
