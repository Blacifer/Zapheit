# secret_supabase_url                  = "https://xxxx.supabase.co"
# secret_supabase_anon_key             = ""
# secret_supabase_service_key          = ""
# secret_jwt_secret                    = ""
# secret_database_url                  = ""
# secret_frontend_url                  = "https://www.zapheit.com"
# secret_api_url                       = ""   # fill after first deploy
# secret_cors_allowed_origins          = "https://www.zapheit.com"
