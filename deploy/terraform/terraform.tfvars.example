# deploy/terraform/terraform.tfvars.example
# Copy to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored — never commit it with real secrets.

project_id  = "rasisynthetichr"
region      = "asia-south1"
environment = "production"  # or "staging"

# Optional: pin a specific image tag instead of "latest"
# api_image     = "asia-south1-docker.pkg.dev/rasisynthetichr/zapheit/zapheit-api:abc1234"
# runtime_image = "asia-south1-docker.pkg.dev/rasisynthetichr/zapheit/zapheit-runtime:abc1234"

# ── Secrets (Option A: manage via Terraform) ──────────────────────────────────
# Leave blank to skip writing a version — populate via deploy/gcp/secrets.sh instead.
