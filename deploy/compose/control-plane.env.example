# Copy to control-plane.env and fill values.

NODE_ENV=production
PORT=3001

# Supabase (hosted or self-hosted)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Auth
JWT_SECRET=your-jwt-secret-here

# App URLs (required in production)
FRONTEND_URL=http://localhost:8080
API_URL=http://localhost:3001

# Optional integrations (examples)
EMAIL_PROVIDER=webhook
EMAIL_FROM=no-reply@your-domain.com
EMAIL_WEBHOOK_URL=https://example.com/send-email
ALERT_EMAIL_TO=oncall@your-domain.com

# AI providers
OPENAI_API_KEY=sk-your-openai-key

