# SyntheticHR self-host environment template
# Copy to stack.env and fill in all required values before running docker-compose.
#
#   cp deploy/compose/stack.env.example deploy/compose/stack.env

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=synthetic_hr
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_PORT=5432

# ── API ────────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
SYNTHETICHR_API_PORT=3001

# Supabase (cloud or self-hosted)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Auth
JWT_SECRET=change-me-random-256-bit-secret

# App URLs
FRONTEND_URL=http://localhost:8080
API_URL=http://localhost:3001

# AI providers
OPENAI_API_KEY=sk-your-openai-key

# Optional integrations
EMAIL_PROVIDER=webhook
EMAIL_FROM=no-reply@your-domain.com
EMAIL_WEBHOOK_URL=https://example.com/send-email
ALERT_EMAIL_TO=oncall@your-domain.com

# ── Frontend ───────────────────────────────────────────────────────────────────
SYNTHETICHR_FRONTEND_PORT=8080
SYNTHETICHR_API_URL=http://localhost:3001/api
SYNTHETICHR_SUPABASE_URL=https://your-project.supabase.co
SYNTHETICHR_SUPABASE_ANON_KEY=your-anon-key-here
SYNTHETICHR_SENTRY_DSN=
SYNTHETICHR_APP_VERSION=
SYNTHETICHR_ERROR_REPORTING_URL=

# ── Runtime worker (only needed with --profile runtime) ────────────────────────
SYNTHETICHR_CONTROL_PLANE_URL=http://synthetic-hr-api:3001
SYNTHETICHR_GATEWAY_URL=
SYNTHETICHR_RUNTIME_ID=your-runtime-id
SYNTHETICHR_ENROLLMENT_TOKEN=your-enrollment-token
SYNTHETICHR_RUNTIME_SECRET=
SYNTHETICHR_RUNTIME_SECRET_FILE=/data/runtime_secret
SYNTHETICHR_API_KEY=your-api-key
SYNTHETICHR_POLL_INTERVAL_MS=2000
SYNTHETICHR_HEARTBEAT_INTERVAL_MS=15000
SYNTHETICHR_MODEL=openai/gpt-4o-mini
SYNTHETICHR_STREAM_MODE=poll
