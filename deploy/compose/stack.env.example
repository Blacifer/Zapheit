# Zapheit self-host environment template
# Copy to stack.env and fill in all required values before running docker-compose.
#
#   cp deploy/compose/stack.env.example deploy/compose/stack.env

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=synthetic_hr
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_PORT=5432

# ── API ────────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
ZAPHEIT_API_PORT=3001

# Supabase (cloud or self-hosted)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Auth
JWT_SECRET=change-me-random-256-bit-secret

# App URLs
FRONTEND_URL=http://localhost:8080
API_URL=http://localhost:3001

# AI providers
OPENAI_API_KEY=sk-your-openai-key

# Optional integrations
EMAIL_PROVIDER=webhook
EMAIL_FROM=no-reply@your-domain.com
EMAIL_WEBHOOK_URL=https://example.com/send-email
ALERT_EMAIL_TO=oncall@your-domain.com

# ── Frontend ───────────────────────────────────────────────────────────────────
ZAPHEIT_FRONTEND_PORT=8080
ZAPHEIT_API_URL=http://localhost:3001/api
ZAPHEIT_SUPABASE_URL=https://your-project.supabase.co
ZAPHEIT_SUPABASE_ANON_KEY=your-anon-key-here
ZAPHEIT_SENTRY_DSN=
ZAPHEIT_APP_VERSION=
ZAPHEIT_ERROR_REPORTING_URL=

# ── Runtime worker (only needed with --profile runtime) ────────────────────────
ZAPHEIT_CONTROL_PLANE_URL=http://zapheit-api:3001
ZAPHEIT_GATEWAY_URL=
ZAPHEIT_RUNTIME_ID=your-runtime-id
ZAPHEIT_ENROLLMENT_TOKEN=your-enrollment-token
ZAPHEIT_RUNTIME_SECRET=
ZAPHEIT_RUNTIME_SECRET_FILE=/data/runtime_secret
ZAPHEIT_API_KEY=your-api-key
ZAPHEIT_POLL_INTERVAL_MS=2000
ZAPHEIT_HEARTBEAT_INTERVAL_MS=15000
ZAPHEIT_MODEL=openai/gpt-4o-mini
ZAPHEIT_STREAM_MODE=poll
