# Backend Environment Variables - TEMPLATE
# 
# INSTRUCTIONS:
# 1. For LOCAL DEVELOPMENT: Copy to .env.local
# 2. For TESTING: Use .env.test
# 3. For STAGING: Use .env.staging
# 4. For PRODUCTION: Use .env.production (never commit)
#
# ⚠️ IMPORTANT: Never commit .env files with real credentials to git!
#
# Environment Hierarchy:
# development (local) → test → staging → production
# Each environment uses separate credentials and databases

# ============ Supabase ============
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ============ Authentication ============
# JWT secret - use Supabase's JWT_SECRET or your own
JWT_SECRET=your-jwt-secret-here

# ============ Server ============
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# ============ Observability (NEW) ============
# OpenTelemetry configuration
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_TIMEOUT=10000
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_TRACES_EXPORTER=console
OTEL_METRICS_EXPORTER=console

# ============ Database (NEW) ============
DATABASE_URL=postgresql://postgres:password@localhost:5432/synthetic_hr

# ============ Integration Credential Encryption ============
# Dedicated key for encrypting stored integration credentials (AES-256-GCM)
# Generate with: openssl rand -hex 32
INTEGRATIONS_ENCRYPTION_KEY=your-32-byte-hex-key-here

# ============ OAuth Integrations ============
# Redirect URL pattern: {BACKEND_URL}/api/integrations/oauth/callback/<service>

# Google Workspace
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Slack
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_SIGNING_SECRET=   # Basic Information > Signing Secret (for inbound event webhook verification)

# Zoho (People / Recruit / Learn)
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=

# LinkedIn
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=

# Microsoft 365 / Teams
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# Deel
# DEEL_CLIENT_ID=
# DEEL_CLIENT_SECRET=

# Gusto
# GUSTO_CLIENT_ID=
# GUSTO_CLIENT_SECRET=

# Flock
# FLOCK_CLIENT_ID=
# FLOCK_CLIENT_SECRET=

# Okta
# OKTA_CLIENT_ID=
# OKTA_CLIENT_SECRET=

# DigiLocker (India)
# DIGILOCKER_CLIENT_ID=
# DIGILOCKER_CLIENT_SECRET=

# Salesforce
# SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET=

# HubSpot
# HUBSPOT_CLIENT_ID=
# HUBSPOT_CLIENT_SECRET=

# Intercom
# INTERCOM_CLIENT_ID=
# INTERCOM_CLIENT_SECRET=

# QuickBooks (Intuit) — uses Authorization: Basic header for token exchange
# QUICKBOOKS_CLIENT_ID=
# QUICKBOOKS_CLIENT_SECRET=

# ============ External Integrations ============
# Slack webhook for incident notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# PagerDuty integration
PAGERDUTY_API_TOKEN=your-pagerduty-api-token
PAGERDUTY_SERVICE_ID=your-pagerduty-service-id
PAGERDUTY_INTEGRATION_KEY=your-pagerduty-integration-key

# Email delivery (required in production)
# EMAIL_PROVIDER supports: resend | webhook
EMAIL_PROVIDER=resend
EMAIL_FROM=no-reply@your-domain.com
RESEND_API_KEY=re_your_resend_api_key
# EMAIL_WEBHOOK_URL=https://your-email-webhook.example/send
ALERT_EMAIL_TO=oncall@your-domain.com

# ============ AI Services ============
# OpenAI
OPENAI_API_KEY=sk-your-openai-key
# Optional dedicated key used by Rasi gateway /v1 routes
RASI_OPENAI_API_KEY=sk-your-rasi-openai-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-key
# Optional dedicated key used by Rasi gateway /v1 routes
RASI_ANTHROPIC_API_KEY=your-rasi-anthropic-key

# OpenRouter (Phase 2 model expansion)
OPENROUTER_API_KEY=sk-or-your-openrouter-key
# Optional dedicated key used by Rasi gateway /v1 routes
RASI_OPENROUTER_API_KEY=sk-or-your-rasi-openrouter-key


# ============ Logging & Monitoring ============
# Sentry (optional)
# SENTRY_DSN=https://your@sentry.io/project
